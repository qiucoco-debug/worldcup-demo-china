      
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>我的观赛分身·世界杯 | 抖音搜索</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
        }

        body {
            background-color: #f5f5f5;
            padding: 16px;
            max-width: 420px;
            margin: 0 auto;
        }

        .container {
            background-color: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        }

        .page-title {
            text-align: center;
            padding: 20px 0;
            font-size: 20px;
            font-weight: 600;
            background: linear-gradient(120deg, #165DFF, #00C6FF);
            color: #fff;
            letter-spacing: 1px;
        }

        /* 核心视觉区 */
        .persona-card {
            padding: 24px 20px;
            position: relative;
            background: linear-gradient(180deg, #f8f9ff 0%, #fff 100%);
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .persona-left {
            flex-shrink: 0;
        }

        .avatar-container {
            width: 140px;
            height: 140px;
            margin: 0 auto;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .avatar {
            width: 110px;
            height: 110px;
        }

        .float-element {
            position: absolute;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background-color: rgba(255,255,255,0.9);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            animation: float 3s ease-in-out infinite;
        }

        .float-element:nth-child(2) {
            top: 0;
            right: 5px;
            animation-delay: 0s;
        }

        .float-element:nth-child(3) {
            bottom: 15px;
            left: 0;
            animation-delay: 1s;
        }

        .float-element:nth-child(4) {
            top: 25px;
            left: -5px;
            animation-delay: 2s;
        }

        .float-element:nth-child(5) {
            top: 10px;
            right: -8px;
            animation-delay: 0.5s;
        }

        @keyframes float {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-6px); }
        }

        .persona-right {
            flex: 1;
            text-align: left;
        }

        .persona-tag {
            font-size: 22px;
            font-weight: 700;
            color: #165DFF;
            margin-bottom: 8px;
        }

        .persona-desc {
            font-size: 14px;
            color: #666;
            margin-bottom: 12px;
            line-height: 1.6;
        }

        .persona-insight {
            font-size: 13px;
            color: #999;
            margin-top: 10px;
            padding: 8px 10px;
            background: rgba(22, 93, 255, 0.06);
            border-radius: 8px;
            line-height: 1.6;
        }

        /* 数据板块通用样式 */
        .data-section {
            padding: 20px;
            border-top: 1px solid #f0f0f0;
        }

        .section-title {
            font-size: 16px;
            font-weight: 600;
            color: #333;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .section-summary {
            font-size: 13px;
            color: #888;
            margin-top: -8px;
            margin-bottom: 16px;
            line-height: 1.6;
        }

        .section-summary strong {
            color: #165DFF;
        }

        /* 看看其他球队 - 热搜列表 */
        .hot-team-list {
            list-style: none;
        }

        .hot-team-item {
            display: flex;
            align-items: center;
            padding: 12px 14px;
            margin-bottom: 10px;
            background: #f8f9ff;
            border-radius: 12px;
            cursor: pointer;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .hot-team-item:last-child {
            margin-bottom: 0;
        }

        .hot-team-item:hover {
            transform: translateY(-1px);
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

        .hot-team-item:active {
            transform: translateY(0);
        }

        .hot-team-rank {
            width: 24px;
            font-size: 14px;
            color: #999;
            text-align: center;
            flex-shrink: 0;
            font-weight: 600;
        }

        .hot-team-rank.top1 { color: #FF6B35; font-weight: 700; }
        .hot-team-rank.top2 { color: #FF9F43; font-weight: 700; }
        .hot-team-rank.top3 { color: #FECA57; font-weight: 700; }

        .hot-team-flag {
            font-size: 22px;
            margin: 0 10px;
            flex-shrink: 0;
        }

        .hot-team-info {
            flex: 1;
        }

        .hot-team-name {
            font-size: 15px;
            color: #333;
            font-weight: 500;
        }

        .hot-team-query {
            font-size: 12px;
            color: #bbb;
            margin-top: 2px;
        }

        .hot-team-heat {
            font-size: 12px;
            color: #FF6B35;
            white-space: nowrap;
            flex-shrink: 0;
            margin-left: 8px;
        }

        .hot-team-arrow {
            font-size: 14px;
            color: #ccc;
            margin-left: 4px;
            flex-shrink: 0;
        }

        /* 分享区域 */
        .share-section {
            padding: 20px;
            border-top: 1px solid #f0f0f0;
            text-align: center;
        }

        .share-btn {
            display: inline-block;
            width: 80%;
            height: 48px;
            line-height: 48px;
            background: linear-gradient(90deg, #165DFF, #00C6FF);
            color: #fff;
            border-radius: 24px;
            text-align: center;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            box-shadow: 0 4px 16px rgba(22, 93, 255, 0.35);
            transition: transform 0.2s, box-shadow 0.2s;
            text-decoration: none;
        }

        .share-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(22, 93, 255, 0.45);
        }

        .share-btn:active {
            transform: translateY(0);
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- 页面标题 -->
        <div class="page-title">🏆 我的观赛分身·世界杯</div>

        <!-- 核心视觉区 - 佛系看球人 -->
        <div class="persona-card">
            <div class="persona-left">
                <div class="avatar-container">
                    <!-- 呆萌Q弹小男孩：身穿中国红配色球衣 -->
                    <svg class="avatar" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                        <!-- 身体阴影 -->
                        <ellipse cx="100" cy="190" rx="35" ry="5" fill="#e0e0e0" opacity="0.4"/>
                        
                        <!-- 身体/球衣 - 中国红配色 -->
                        <rect x="65" y="115" width="70" height="65" rx="16" fill="#DE2910"/>
                        <!-- 球衣黄色装饰条 -->
                        <rect x="65" y="128" width="70" height="10" rx="2" fill="#FFDE00" opacity="0.85"/>
                        <rect x="65" y="152" width="70" height="10" rx="2" fill="#FFDE00" opacity="0.85"/>
                        <!-- 球衣号码 -->
                        <text x="100" y="148" text-anchor="middle" font-size="18" font-weight="bold" fill="#fff" font-family="Arial, sans-serif">10</text>
                        
                        <!-- 胳膊 -->
                        <rect x="48" y="118" width="20" height="40" rx="10" fill="#DE2910"/>
                        <rect x="132" y="118" width="20" height="40" rx="10" fill="#DE2910"/>
                        <!-- 手 -->
                        <circle cx="58" cy="162" r="9" fill="#FDDCB5"/>
                        <circle cx="142" cy="162" r="9" fill="#FDDCB5"/>
                        
                        <!-- 头部 -->
                        <circle cx="100" cy="82" r="38" fill="#FDDCB5"/>
                        
                        <!-- 头发 -->
                        <ellipse cx="100" cy="58" rx="36" ry="22" fill="#4A3728"/>
                        <rect x="64" y="52" width="72" height="16" rx="8" fill="#4A3728"/>
                        
                        <!-- 眼睛 - 看向右上方（思考/远望的感觉） -->
                        <ellipse cx="86" cy="84" rx="6" ry="7" fill="#333"/>
                        <ellipse cx="114" cy="84" rx="6" ry="7" fill="#333"/>
                        <!-- 眼睛高光 - 偏右上 -->
                        <circle cx="89" cy="81" r="2.5" fill="#fff"/>
                        <circle cx="117" cy="81" r="2.5" fill="#fff"/>
                        
                        <!-- 腮红 -->
                        <ellipse cx="74" cy="94" rx="8" ry="5" fill="#FFB6C1" opacity="0.5"/>
                        <ellipse cx="126" cy="94" rx="8" ry="5" fill="#FFB6C1" opacity="0.5"/>
                        
                        <!-- 嘴巴 - 微笑偏佛系 -->
                        <path d="M 92 100 Q 100 108 108 100" stroke="#c47a5a" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                        
                        <!-- 腿 -->
                        <rect x="74" y="174" width="18" height="14" rx="8" fill="#FDDCB5"/>
                        <rect x="108" y="174" width="18" height="14" rx="8" fill="#FDDCB5"/>
                        <!-- 鞋子 -->
                        <rect x="70" y="182" width="26" height="12" rx="6" fill="#333"/>
                        <rect x="104" y="182" width="26" height="12" rx="6" fill="#333"/>
                    </svg>
                    
                    <div class="float-element">🇨🇳</div>
                    <div class="float-element">⚽</div>
                    <div class="float-element">😐</div>
                    <div class="float-element">🤔</div>
                </div>
            </div>
            <div class="persona-right">
                <div class="persona-tag">佛系看球人</div>
                <div class="persona-desc">这次世界杯好像没有你关注的队伍哦，也许，你在等一支特别的队伍！</div>
                <div class="persona-insight">🏀 比赛很精彩，但还未检测到你在追哪支主队…也许，每一次进球你都在欢呼。</div>
            </div>
        </div>

        <!-- 看看其他球队 -->
        <div class="data-section">
            <div class="section-title">🔥 看看其他球队</div>
            <div class="section-summary">既然你的主队不在场上，看看网友们的热门关注吧</div>
            <ul class="hot-team-list">
                <li class="hot-team-item">
                    <div class="hot-team-rank top1">1</div>
                    <div class="hot-team-flag">🇧🇷</div>
                    <div class="hot-team-info">
                        <div class="hot-team-name">巴西</div>
                        <div class="hot-team-query">巴西 vs 韩国比分</div>
                    </div>
                    <div class="hot-team-heat">🔥 3.2万</div>
                    <div class="hot-team-arrow">›</div>
                </li>
                <li class="hot-team-item">
                    <div class="hot-team-rank top2">2</div>
                    <div class="hot-team-flag">🇦🇷</div>
                    <div class="hot-team-info">
                        <div class="hot-team-name">阿根廷</div>
                        <div class="hot-team-query">阿根廷世界杯大名单</div>
                    </div>
                    <div class="hot-team-heat">🔥 2.8万</div>
                    <div class="hot-team-arrow">›</div>
                </li>
                <li class="hot-team-item">
                    <div class="hot-team-rank top3">3</div>
                    <div class="hot-team-flag">🇫🇷</div>
                    <div class="hot-team-info">
                        <div class="hot-team-name">法国</div>
                        <div class="hot-team-query">姆巴佩 世界杯表现</div>
                    </div>
                    <div class="hot-team-heat">🔥 2.5万</div>
                    <div class="hot-team-arrow">›</div>
                </li>
    
            </ul>
        </div>

        <!-- 分享区域 -->
        <div class="share-section">
            <a href="#" class="share-btn">📤 分享我的观赛分身</a>
        </div>
    </div>

    <script>
        // 热搜球队点击
        document.querySelectorAll('.hot-team-item').forEach(item => {
            item.addEventListener('click', () => {
                const teamName = item.querySelector('.hot-team-name').textContent;
                alert(`正在搜索：${teamName} | 世界杯`);
            });
        });

        // 分享按钮
        document.querySelector('.share-btn').addEventListener('click', (e) => {
            e.preventDefault();
            alert('已生成你的观赛分身海报，可分享给好友～');
        });
    </script>
</body>
</html>

    
